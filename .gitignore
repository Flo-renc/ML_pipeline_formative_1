# ════════════════════════════════════════════════════════════════════════════
#                      Sougnabe's changes start
# ════════════════════════════════════════════════════════════════════════════
# Python
# ════════════════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# ════════════════════════════════════════════════════════════════════════════
# Virtual Environments
# ════════════════════════════════════════════════════════════════════════════
venv/
env/
ENV/
.venv

# ════════════════════════════════════════════════════════════════════════════
# Environment Variables (IMPORTANT - DO NOT COMMIT!)
# ════════════════════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local

# ════════════════════════════════════════════════════════════════════════════
# Dataset (Large file - do not commit)
# ════════════════════════════════════════════════════════════════════════════
data/household_power_consumption.txt
data/*.txt
data/*.csv
data/*.zip

# ════════════════════════════════════════════════════════════════════════════
# Model Outputs (Can be large)
# ════════════════════════════════════════════════════════════════════════════
outputs/models/*.pkl
outputs/models/*.h5
outputs/models/*.joblib
*.pkl
*.h5
*.joblib

# Keep the outputs directory structure but not the files
!outputs/.gitkeep
!outputs/models/.gitkeep
!outputs/visualizations/.gitkeep
!outputs/results/.gitkeep

# ════════════════════════════════════════════════════════════════════════════
# IDE
# ════════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ════════════════════════════════════════════════════════════════════════════
# Jupyter Notebooks
# ════════════════════════════════════════════════════════════════════════════
.ipynb_checkpoints/
*.ipynb

# ════════════════════════════════════════════════════════════════════════════
# Testing
# ════════════════════════════════════════════════════════════════════════════
.pytest_cache/
.coverage
htmlcov/

# ════════════════════════════════════════════════════════════════════════════
# Logs
# ════════════════════════════════════════════════════════════════════════════
*.log
logs/

# ════════════════════════════════════════════════════════════════════════════
# SOUGNABE'S NOTE:
# This .gitignore protects sensitive data and large files from being committed
# Key protections:
#   - .env file (contains passwords and credentials)
#   - Dataset file (127 MB - too large for GitHub)
#   - Trained models (can be regenerated)
# ════════════════════════════════════════════════════════════════════════════
#                     Sougnabe's Change ending

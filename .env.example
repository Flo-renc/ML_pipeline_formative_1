# WHAT: Environment Variables Configuration Template
# WHY:  Provide clear documentation for required environment variables
# INCLUDES: MySQL, MongoDB, and dataset configuration
# 
# ════════════════════════════════════════════════════════════════════════════

# ============================================================================
# MySQL Database Configuration
# ============================================================================

# MySQL host (use 'localhost' for local or IP for remote)
DB_HOST=localhost

# MySQL port (default: 3306)
DB_PORT=3306

# MySQL username
DB_USER=root

# MySQL password (CHANGE THIS!)
DB_PASSWORD=your_mysql_password_here

# Database name
DB_NAME=power_consumption

# ============================================================================
# MongoDB Configuration
# ============================================================================

# MongoDB connection URI
# Local: mongodb://localhost:27017/
# Docker: mongodb://localhost:27017/
# Remote: mongodb://username:password@host:port/
MONGO_URI=mongodb://localhost:27017/

# ============================================================================
# Dataset Configuration
# ============================================================================

# Path to the household power consumption dataset
# Download from: https://www.kaggle.com/datasets/uciml/electric-power-consumption-data-set
DATASET_PATH=data/household_power_consumption.txt

# ============================================================================
# API Configuration (Optional)
# ============================================================================

# MySQL API Port
MYSQL_API_PORT=5000

# MongoDB API Port
MONGO_API_PORT=8000

# ============================================================================
# Instructions
# ============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Update the values above with your actual credentials
#
# 3. NEVER commit .env to git (it's in .gitignore)
#
# 4. Make sure the dataset file is downloaded and placed in data/ folder
#
